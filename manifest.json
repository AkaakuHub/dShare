{
    "manifest_version": 3,
    "name": "dShare",
    "version": "1.0",
    "description": "PC版dアニメストアにツイートボタンを追加します。",
    "author": "Akaaku",
    "browser_specific_settings": {
        "gecko": {
            "id": "{6a2f8a1b-3d9e-4717-9cbe-0f5dab61fc27}",
            "strict_min_version": "42.0"
        }
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "images/icon16.png",
            "32": "images/icon16.png",
            "48": "images/icon16.png",
            "64": "images/icon64.png",
            "128": "images/icon128.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "https://animestore.docomo.ne.jp/animestore/*"
            ],
            "js": [
                "content-script.js"
            ]
        }
    ]
}
